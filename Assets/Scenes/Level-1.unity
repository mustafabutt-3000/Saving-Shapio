  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "This is Shapio. A world where geometry is law. Where every shape has its
    place, and the rules of this world hold everything together.\nBut the rules are
    breaking.\nThings move that shouldn't. Things vanish that should stay. Forces
    pull and push where they have no right to. The very logic of this world is being
    rewritten.\nAnd look closely \u2014 do you notice? The circles are gone. The
    spheres. The curves. Every soft edge, every rounded form... disappearing.\nThis
    isn't decay. This is design.\nYou are a Cube. Small. Glowing. Searching for answers
    in a world that's being unmade.\nSomething out there has a vision for Shapio.\nAnd
    there's no room for you in it.\""
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 125cb55b44b24c4393181402bc6200e6, type: 2}
